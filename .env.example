# --- Supabase (data layer) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk (auth layer) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Signing secret from the Clerk webhook endpoint you create
CLERK_WEBHOOK_SECRET=
# Optional: override default routing
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
# Send everyone to /post-auth after sign-in. That page decides whether to
# forward them to /onboarding (new user, no profile.role yet) or /dashboard
# (returning user). Clerk only supports a single AFTER_SIGN_IN_URL so the
# branching has to live in our own route.
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/post-auth
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/post-auth

# --- Twilio (WhatsApp OTP via Messages API + Lookup for phone validation) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# WhatsApp sender, prefixed with "whatsapp:". Sandbox = whatsapp:+14155238886.
# Production: use an approved WhatsApp Business API sender from Twilio console.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Content template SID carrying the OTP. Sandbox default works:
# "*{{1}}* is your verification code. For your security, do not share this code."
TWILIO_WHATSAPP_OTP_CONTENT_SID=HX229f5a04fd0510ce1b071852155d3e75
# SMS fallback sender — a Twilio phone number in E.164 format (e.g. +15551234567).
# Used when WhatsApp delivery fails. Get a number at console.twilio.com.
TWILIO_SMS_FROM=
RESEND_API_KEY=
OPENAI_API_KEY=
# --- AirLabs (flight data API — static routes, DB-cached after first call) ---
# Free tier is enough for launch; /routes endpoint works for every flight.
# Get your key at https://airlabs.co
AIRLABS_API_KEY=
# --- Rate limiting (Upstash — not wired yet, will add later) ---
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SENTRY_DSN=
# Client-side DSN — can be the same as SENTRY_DSN. If unset, browser errors
# are not captured (server-side still is).
NEXT_PUBLIC_SENTRY_DSN=
# For source-map upload on prod builds. Create at
# sentry.io → Settings → Account → API → Auth Tokens.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://getsaathi.com
# Cron shared secret to protect /api/cron/* endpoints
CRON_SECRET=
# Feature flag — set to "true" to unlock the (not-yet-built) in-app chat,
# mark-complete, reviews, and photo upload on /match/[id]. Default off shows
# a single "coming soon" notice instead of three half-built stub cards.
NEXT_PUBLIC_MATCH_FEATURES_ENABLED=false
